# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321

# Database
DATABASE_URL=postgresql+asyncpg://vpn_bot:changeme@postgres:5432/vpn_bot_db
POSTGRES_USER=vpn_bot
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vpn_bot_db

# Redis
REDIS_URL=redis://redis:6379/0

# Marzban VPN Panel
MARZBAN_URL=https://your-marzban-domain.com
MARZBAN_USERNAME=admin
MARZBAN_PASSWORD=admin
MARZBAN_INSECURE=false

# YooKassa
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key
YOOKASSA_CALLBACK_URL=https://your-domain.com/webhook/yookassa

# CloudPayments
CLOUDPAYMENTS_PUBLIC_ID=your_public_id
CLOUDPAYMENTS_API_SECRET=your_api_secret
CLOUDPAYMENTS_CALLBACK_URL=https://your-domain.com/webhook/cloudpayments

# CryptoBot
CRYPTOBOT_TOKEN=your_cryptobot_token
CRYPTOBOT_CALLBACK_URL=https://your-domain.com/webhook/cryptobot

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD=strong_password_here

# App Settings
DEBUG=false
LOG_LEVEL=INFO
WEBHOOK_URL=https://your-domain.com/webhook/telegram
BOT_DOMAIN=your-domain.com
